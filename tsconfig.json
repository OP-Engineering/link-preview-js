{
  "compilerOptions": {
    "outDir": "build",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "declaration": true,
    "target": "es6",
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "types": [
      "jest"
    ]
  },
  "exclude": [
    "node_modules",
    "build"
  ]
}